# Twilio Credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Airtable Credentials
AIRTABLE_API_KEY=patxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxxx

# Game Settings
RESET_CONFIRM_CODE=your_secret_reset_code

# Security & Fraud Prevention
ALLOW_SMS=false                # Enable/disable SMS/MMS sending (default: false)
ALLOW_WHATSAPP=true            # Enable/disable WhatsApp sending (default: true)
RATE_LIMIT_SECONDS=3           # Minimum seconds between messages per user (default: 3)

# Game Configuration
STAMPS_REQUIRED=10             # Number of stamps required to complete game and redeem prize (default: 10)

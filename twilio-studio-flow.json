{
  "description": "Global Connect Game - Complete",
  "flags": {
    "allow_concurrent_calls": true
  },
  "initial_state": "Trigger",
  "states": [
    {
      "name": "Trigger",
      "properties": {
        "offset": {
          "x": 0,
          "y": 0
        }
      },
      "transitions": [
        {
          "event": "incomingMessage",
          "next": "validate_stamp"
        },
        {
          "event": "incomingCall"
        },
        {
          "event": "incomingConversationMessage"
        },
        {
          "event": "incomingRequest"
        },
        {
          "event": "incomingParent"
        }
      ],
      "type": "trigger"
    },
    {
      "name": "validate_stamp",
      "properties": {
        "add_twilio_auth": false,
        "content_type": "application/x-www-form-urlencoded",
        "method": "POST",
        "offset": {
          "x": 0,
          "y": 200
        },
        "parameters": [
          {
            "key": "collectorPhone",
            "value": "{{trigger.message.From}}"
          },
          {
            "key": "targetCode",
            "value": "{{trigger.message.Body}}"
          }
        ],
        "url": "https://YOUR-SERVICE-NAME.twil.io/validate-stamp"
      },
      "transitions": [
        {
          "event": "success",
          "next": "check_action"
        },
        {
          "event": "failed",
          "next": "system_error"
        }
      ],
      "type": "make-http-request"
    },
    {
      "name": "check_action",
      "properties": {
        "input": "{{widgets.validate_stamp.parsed.action}}",
        "offset": {
          "x": -20,
          "y": 470
        }
      },
      "transitions": [
        {
          "event": "noMatch",
          "next": "system_error"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.action}}"
              ],
              "friendly_name": "Is Activation",
              "type": "equal_to",
              "value": "activate"
            }
          ],
          "event": "match",
          "next": "send_activation"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.action}}"
              ],
              "friendly_name": "Is Stamp",
              "type": "equal_to",
              "value": "stamp_collected"
            }
          ],
          "event": "match",
          "next": "same_language"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.action}}"
              ],
              "friendly_name": "Is Error",
              "type": "equal_to",
              "value": "error"
            }
          ],
          "event": "match",
          "next": "check_action_error"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.action}}"
              ],
              "friendly_name": "If value equal_to started",
              "type": "matches_any_of",
              "value": "started, start"
            }
          ],
          "event": "match",
          "next": "form_activation"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.action}}"
              ],
              "friendly_name": "If value equal_to game_ended",
              "type": "equal_to",
              "value": "game_ended"
            }
          ],
          "event": "match",
          "next": "game_over"
        }
      ],
      "type": "split-based-on"
    },
    {
      "name": "send_activation",
      "properties": {
        "body": "{{widgets.validate_stamp.parsed.collector.personalizedGreeting.value}}\n\nYour passport is active 🎉! Meet 10 other people to unlock your 'Global Artist' magnet and gift 🎁. Just enter their 4-digit badge code here!\n\nEnjoy your travels ✈️!!!",
        "from": "{{flow.channel.address}}",
        "message_type": "custom",
        "offset": {
          "x": -220,
          "y": 950
        },
        "to": "{{trigger.message.From}}"
      },
      "transitions": [
        {
          "event": "sent"
        },
        {
          "event": "failed"
        }
      ],
      "type": "send-message"
    },
    {
      "name": "send_completion",
      "properties": {
        "body": "Passport Validated! 🎉\n\nYou've traveled the world tonight. Head to the Global Art Wall and add your mark to our collective masterpiece. Show this text to the attendant for your gift.\n\nWait!!! Collect more stamps and be at the top of the leaderboard for additional prizes 🎁!",
        "from": "{{flow.channel.address}}",
        "message_type": "custom",
        "offset": {
          "x": 430,
          "y": 1870
        },
        "to": "{{trigger.message.From}}"
      },
      "transitions": [
        {
          "event": "sent",
          "next": "send_stamp_target"
        },
        {
          "event": "failed"
        }
      ],
      "type": "send-message"
    },
    {
      "name": "send_stamp_collector",
      "properties": {
        "body": "Stamp Collected! \n\nYou just met {{widgets.validate_stamp.parsed.target.name}} ({{widgets.validate_stamp.parsed.target.country}}). \n\n{% if widgets.validate_stamp.parsed.target.linkedin %}LinkedIn: http://www.linkedin.com/{{widgets.validate_stamp.parsed.target.linkedin}} {% endif %}\n\n{{widgets.validate_stamp.parsed.newStampCount}}/5 stamps collected.",
        "content_sid": "HXbb376c8977326f588f4185accb59a152",
        "content_variables": [
          {
            "key": "1",
            "value": "{{widgets.validate_stamp.parsed.target.name}}"
          },
          {
            "key": "2",
            "value": "{{widgets.validate_stamp.parsed.target.countryFlag}}"
          },
          {
            "key": "4",
            "value": "{{widgets.validate_stamp.parsed.target.linkedin.value}}"
          },
          {
            "key": "3",
            "value": "{{widgets.validate_stamp.parsed.target.stampsGreeting.value}}"
          }
        ],
        "from": "{{flow.channel.address}}",
        "message_type": "content_template",
        "offset": {
          "x": 380,
          "y": 1270
        },
        "to": "{{trigger.message.From}}"

    {
      "name": "check_action_error",
      "properties": {
        "input": "{{widgets.validate_stamp.parsed.errorType}}",
        "offset": {
          "x": 1190,
          "y": 890
        }
      },
      "transitions": [
        {
          "event": "noMatch"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.errorType}}"
              ],
              "friendly_name": "If value equal_to not_registered",
              "type": "equal_to",
              "value": "not_registered"
            }
          ],
          "event": "match",
          "next": "not_registered"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.errorType}}"
              ],
              "friendly_name": "If value equal_to invalid_code",
              "type": "equal_to",
              "value": "invalid_code"
            }
          ],
          "event": "match",
          "next": "invalid_code"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.errorType}}"
              ],
              "friendly_name": "If value equal_to duplicate_stamp",
              "type": "equal_to",
              "value": "duplicate_stamp"
            }
          ],
          "event": "match",
          "next": "duplicate_stamp"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.errorType}}"
              ],
              "friendly_name": "If value equal_to missing_parameters",
              "type": "equal_to",
              "value": "missing_parameters"
            }
          ],
          "event": "match",
          "next": "missing_parameters"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.errorType}}"
              ],
              "friendly_name": "If value equal_to already_activated",
              "type": "equal_to",
              "value": "already_activated"
            }
          ],
          "event": "match",
          "next": "already_activated"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.errorType}}"
              ],
              "friendly_name": "If value equal_to not_activated",
              "type": "equal_to",
              "value": "not_activated"
            }
          ],
          "event": "match",
          "next": "not_activated"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.errorType}}"
              ],
              "friendly_name": "If value equal_to invalid_format",
              "type": "equal_to",
              "value": "invalid_format"
            }
          ],
          "event": "match",
          "next": "invalid_format_check"
        },
        {
          "conditions": [
            {
              "arguments": [
                "{{widgets.validate_stamp.parsed.errorType}}"
              ],
              "friendly_name": "If value equal_to url_detected",
              "type": "equal_to",
              "value": "url_detected"
            }
          ],
          "event": "match",
          "next": "url_detected"
        }
      ],
      "type": "split-based-on"
    },
